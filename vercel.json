{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node",
      "config": { "maxDuration": 60 }
    }
  ],
  "routes": [
    { "src": "/health",            "dest": "src/index.js" },
    { "src": "/telegram-webhook",  "dest": "src/index.js" },
    { "src": "/api/(.*)",          "dest": "src/index.js" }
  ],
  "crons": [
    {
      "path": "/api/cron/analyze",
      "schedule": "0 0 * * 1-5"
    }
  ]
}
